{
  "name": "xeno-agentic-crm",
  "private": true,
  "version": "2.0.0",
  "description": "Agentic Xeno CRM with Next.js, FastAPI, Postgres, Redis, BullMQ and OpenRouter.",
  "workspaces": [
    "apps/web",
    "apps/worker"
  ],
  "scripts": {
    "dev:web": "bun --cwd apps/web run dev",
    "dev:worker": "bun --cwd apps/worker run dev",
    "test": "bun --cwd apps/worker test && cd apps/api && python -m pytest tests",
    "lint": "bun --cwd apps/web run lint",
    "compose:up": "docker compose -f infra/docker-compose.yml up --build",
    "compose:down": "docker compose -f infra/docker-compose.yml down -v"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1",
    "python": ">=3.11"
  }
}
